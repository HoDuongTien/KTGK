@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Upload đề thi</title>

    <style>
        body {
            font-family: Arial;
            background: #eef2f7;
            padding: 40px;
        }

        .container {
            max-width: 900px;
            margin: auto;
        }

        .card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.1);
            margin-bottom: 20px;
        }

        h2 {
            margin-bottom: 15px;
        }

        .btn {
            padding: 10px 15px;
            border-radius: 8px;
            border: none;
            cursor: pointer;
        }

        .btn-primary {
            background: #4f46e5;
            color: white;
        }

        /* ===== Question List ===== */
        .question {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            padding: 12px;
            border-bottom: 1px solid #eee;
            gap: 10px;
            transition: 0.2s;
        }

        .question:hover {
            background: #f9fafb;
        }

        .question-content {
            flex: 1;
            line-height: 1.5;
        }

        .question b {
            color: #4f46e5;
        }

        /* ===== Edit Button ===== */
        .btn-edit {
            background: #f59e0b;
            color: white;
            border-radius: 6px;
            padding: 6px 10px;
            font-size: 13px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            height: fit-content;
        }

        .btn-edit:hover {
            background: #d97706;
        }

        input[type="file"] {
            margin-bottom: 10px;
        }
    </style>
</head>

<body>

<div class="container">

    <!-- Upload -->
    <div class="card">
        <h2>📤 Upload đề thi</h2>

        <form asp-action="UploadWord" method="post" enctype="multipart/form-data">
            <input type="file" name="file" />
            <br />
            <button class="btn btn-primary">Upload</button>
        </form>

        <p style="color:green">@ViewBag.Message</p>
    </div>

    <!-- Question List -->
    <div class="card">
        <h2>📋 Danh sách câu hỏi</h2>

        @if(ViewBag.CauHois != null)
        {
            foreach(var q in ViewBag.CauHois)
            {
                <div class="question">
                    
                    <div class="question-content">
                        <b>Câu @q.SoCauHoi:</b> @q.NoiDungCauHoi
                    </div>

                    <a href="/DeThi/Edit/@q.Id" class="btn-edit">
                        ✏️ Sửa
                    </a>

                </div>
            }
        }
    </div>

</div>

</body>
</html>